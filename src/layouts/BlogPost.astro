---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Button from '../components/Button.astro';
import Container from '../components/Container.astro';
import Stack from '../components/Stack.astro';

interface Props extends CollectionEntry<'blog'>['data'] {
	headings?: Array<{ depth: number; slug: string; text: string }>;
}

const { title, description, pubDate, updatedDate, heroImage, headings = [] } = Astro.props;
const tocItems = headings.filter((h) => h.depth === 2);
---

<BaseLayout title={title} description={description} showNav={false}>
	<section class="py-section">
		<Container width="wide">
			<Stack gap="content" as="article">
				{heroImage && (
					<div class="w-full">
						<Image width={1020} height={510} src={heroImage} alt="" class="block h-auto w-full" />
					</div>
				)}
				<div class="rounded-subtle bg-white p-block shadow-card">
					<div class="mb-block border-b border-border pb-content">
						<p class="m-0 text-small text-text-muted">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<span>
										（更新: <FormattedDate date={updatedDate} />）
									</span>
								)
							}
						</p>
						<h1 class="mt-element text-h1">{title}</h1>
					</div>
					{tocItems.length > 0 && (
						<nav class="mb-block rounded-soft border border-border p-content">
							<p class="mb-element font-bold">目次</p>
							<ol class="m-0 list-inside list-decimal space-y-inset p-0">
								{tocItems.map((item) => (
									<li>
										<a href={`#${item.slug}`} class="text-accent no-underline hover:underline">{item.text}</a>
									</li>
								))}
							</ol>
						</nav>
					)}
					<div class="prose">
						<slot />
					</div>
				</div>

				<div class="flex justify-center">
					<Button href="/blog" variant="outline">記事一覧に戻る</Button>
				</div>
			</Stack>
		</Container>
	</section>
</BaseLayout>

<style>
	/*
	  BlogPost の prose ブロックは MDX から生成される DOM を相手にするため、
	  slot 配下の要素に Tailwind class を直接付けられない。
	  よって :global() で残すが、参照する変数は @theme 側の意味ベーストークンに寄せてある。
	  トップレベルのラッパ要素は index.astro 側で Tailwind 化済み。
	*/
	.prose {
		line-height: var(--line-height-body);
		color: var(--color-text);
	}

	.prose :global(em) {
		font-style: normal; /* <em> のブラウザデフォルト italic を打ち消す。Tailwind で表現不可のため scoped に残す */
		color: var(--color-text-muted);
	}

	.prose :global(p) {
		margin-bottom: var(--spacing-content);
	}

	.prose :global(h2) {
		margin-top: var(--spacing-region);
		margin-bottom: var(--spacing-content);
		border-left: 4px solid var(--color-accent);
		padding-left: var(--spacing-content);
		font-weight: 700;
		line-height: var(--line-height-heading);
		scroll-margin-top: calc(var(--spacing-header) + var(--spacing-content));
	}

	.prose :global(h3) {
		margin-top: var(--spacing-block);
		margin-bottom: var(--spacing-element);
		font-weight: 700;
	}

	.prose :global(blockquote) {
		border-left: 4px solid var(--color-accent);
		padding-left: var(--spacing-content);
		margin: var(--spacing-content) 0;
		color: var(--color-text-muted);
	}

	.prose :global(code) {
		padding: var(--spacing-inset) var(--spacing-element);
		background: var(--color-bg-surface);
		border-radius: var(--radius-subtle);
		font-size: var(--text-small);
	}

	.prose :global(pre) {
		padding: var(--spacing-content);
		background: var(--color-bg-surface);
		border-radius: var(--radius-soft);
		overflow-x: auto;
	}

	.prose :global(pre code) {
		padding: 0;
		background: transparent;
	}

	/* テーブル */
	.prose :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin-bottom: var(--spacing-content);
	}

	.prose :global(th),
	.prose :global(td) {
		border: 1px solid var(--color-border);
		padding: var(--spacing-element) var(--spacing-content);
		text-align: left;
	}

	.prose :global(th) {
		font-weight: 700;
		background: var(--color-bg-surface);
	}

	/* :::note コンテナ */
	.prose :global(aside.note) {
		margin: var(--spacing-block) 0;
		padding: var(--spacing-content);
		background: var(--color-bg-surface);
		border-left: 4px solid var(--color-accent);
		border-radius: var(--radius-subtle);
	}

	.prose :global(aside.note > p:first-child) {
		margin-top: 0;
	}

	.prose :global(aside.note > p:last-child) {
		margin-bottom: 0;
	}

	/* :muted[...] 装飾 */
	.prose :global(.muted) {
		color: var(--color-text-subtle);
		font-size: var(--text-small);
	}

	.prose :global(.muted a) {
		color: inherit;
		text-decoration: underline;
	}

	/* :::faq コンテナ */
	.prose :global(section.faq) {
		margin: var(--spacing-block) 0;
		display: flex;
		flex-direction: column;
		gap: var(--spacing-element);
	}

	.prose :global(details.faq-item) {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-subtle);
		padding: 0;
		background: var(--color-bg-surface);
	}

	.prose :global(details.faq-item[open]) {
		background: transparent;
	}

	.prose :global(summary.faq-question) {
		margin: 0;
		padding: var(--spacing-element) var(--spacing-content);
		cursor: pointer;
		font-weight: 600;
		list-style: none;
	}

	.prose :global(summary.faq-question::-webkit-details-marker) {
		display: none;
	}

	.prose :global(summary.faq-question::before) {
		content: 'Q. ';
		color: var(--color-accent);
		font-weight: 700;
	}

	.prose :global(details.faq-item[open] summary.faq-question) {
		border-bottom: 1px solid var(--color-border);
	}

	.prose :global(details.faq-item > p) {
		margin: 0;
		padding: var(--spacing-element) var(--spacing-content);
	}
</style>
