<script>
	const slides = document.querySelectorAll<HTMLImageElement>('.hero-slide');
	if (slides.length > 1) {
		let current = 0;
		setInterval(() => {
			slides[current].classList.remove('hero-slide-active');
			current = (current + 1) % slides.length;
			slides[current].classList.add('hero-slide-active');
		}, 5000);
	}
</script>
