---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Button from "../components/Button.astro";
import Container from "../components/Container.astro";
import Stack from "../components/Stack.astro";
import StepNumber from "../components/StepNumber.astro";

const steps = [
	{
		title: "JR高田馬場駅 戸山口へ",
		description: "JR高田馬場駅に着いたら、新大久保方面のホーム端にある戸山口へ進んでください。",
		src: "/images/directions/step-1.png",
		width: 1024,
		height: 1536,
	},
	{
		title: "戸山口の改札を出て左へ",
		description: "戸山口の改札を出たら、左方向へ進みます。",
		src: "/images/directions/step-2.png",
		width: 1024,
		height: 1536,
	},
	{
		title: "地下道を出たら右に曲がる",
		description: "地下道を抜けたら、右に曲がります。",
		src: "/images/directions/step-3.png",
		width: 1024,
		height: 1536,
	},
	{
		title: "セブンイレブンの前を通過",
		description: "右に曲がるとセブンイレブンが見えます。セブンイレブンの前を通って2軒先のビルを左に曲がります。",
		src: "/images/directions/step-4.png",
		width: 1024,
		height: 1536,
	},
	{
		title: "上り坂を進んで大通りへ",
		description: "少し上り坂になっている道を進むと、大通り（つつじ通り）に出ます。",
		src: "/images/directions/step-5.jpg",
		width: 3000,
		height: 4000,
	},
	{
		title: "茶色のレンガビルが目印",
		description: "道を挟んだ前方に茶色のレンガビルがあります。1階は中華料理「敦煌（とんこう）」さんです。",
		src: "/images/directions/step-6.jpg",
		width: 900,
		height: 1200,
	},
	{
		title: "ビル入口",
		description: "敦煌の右隣にスカイパレスビルの入口があります。",
		src: "/images/directions/step-7.jpg",
		width: 900,
		height: 1200,
	},
	{
		title: "テナント案内板",
		description: "入口横の案内板で8Fの「かんおけin」を確認できます。",
		src: "/images/directions/step-8.jpg",
		width: 1080,
		height: 1350,
	},
	{
		title: "エントランス",
		description: "ガラスドアを入り、エレベーターで8階へ上がってください。",
		src: "/images/directions/step-9.jpg",
		width: 900,
		height: 1200,
	},
	{
		title: "801号室",
		description: "8階に着いたら、かんおけinのロゴが目印の801号室です。",
		src: "/images/directions/step-10.jpg",
		width: 1108,
		height: 1477,
	},
];
---

<BaseLayout title="道順ガイド" description="JR高田馬場駅からの道順を写真でご案内します。">
	<section class="py-section">
		<Container width="wide">
			<Stack gap="content">
				<div class="rounded-subtle bg-white p-block shadow-card">
					<SectionHeading>道順ガイド</SectionHeading>
					<p class="text-text-muted">JR高田馬場駅からの道順を写真でご案内します。</p>

					<Stack gap="block">
						{steps.map((step, i) => (
							<Stack gap="element">
								<h3 class="flex items-center gap-element text-body font-bold leading-heading">
									<StepNumber num={i + 1} />
									{step.title}
								</h3>
								<img
									src={step.src}
									alt={step.title}
									width={step.width}
									height={step.height}
									loading="eager"
									class="block h-auto w-full max-w-step-img rounded-subtle"
								/>
								<p class="leading-list text-text-muted">{step.description}</p>
							</Stack>
						))}
					</Stack>
				</div>

				<div class="flex justify-center">
					<Button href="/#access" variant="outline">戻る</Button>
				</div>
			</Stack>
		</Container>
	</section>
</BaseLayout>
