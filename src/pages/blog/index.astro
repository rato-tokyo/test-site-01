---
// kanoke-in v2 の /blog のレイアウトに合わせた記事一覧。
// SectionCard + SectionTitle + 日付・タイトルの1行グリッド。
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Container from "../../components/Container.astro";
import SectionCard from "../../components/SectionCard.astro";
import SectionTitle from "../../components/SectionTitle.astro";
import Button from "../../components/Button.astro";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const formatDate = (date: Date) => date.toISOString().slice(0, 10);
---

<Base title="ブログ" description="ブログ記事一覧">
	<Container width="wide" class="py-snug">
		<SectionCard>
			<SectionTitle>ブログ</SectionTitle>

			{posts.length === 0 ? (
				<p class="text-body text-text-muted">記事はまだありません。</p>
			) : (
				<div class="flex flex-col border-t border-border">
					{posts.map((post) => (
						<a
							href={`/blog/${post.id}/`}
							class="grid grid-cols-[auto_1fr] items-baseline gap-x-snug border-b border-border py-snug no-underline rounded-soft transition-colors duration-fast hover:bg-bg-surface"
						>
							<span class="shrink-0 whitespace-nowrap text-body text-text-muted">
								{formatDate(post.data.pubDate)}
							</span>
							<span class="truncate text-body text-text">
								{post.data.title}
							</span>
						</a>
					))}
				</div>
			)}
		</SectionCard>

		<div class="mt-snug flex justify-center">
			<Button href="/" variant="outline">戻る</Button>
		</div>
	</Container>
</Base>
