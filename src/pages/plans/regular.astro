---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import Button from "../../components/Button.astro";
import Container from "../../components/Container.astro";
import Stack from "../../components/Stack.astro";
import WeekCalendar from "../../components/WeekCalendar.tsx";
import { regularPlanEvents } from "../../lib/calendar-data";
import { GOOGLE_FORM_CONTACT_URL } from "../../consts";
---

<BaseLayout title="通常プラン" description="予約不要・来店順。時間帯ごとに異なる4種類の瞑想プログラムを体験できます。">
	<section class="py-section">
		<Container width="wide">
			<Stack gap="content">
				<div class="rounded-subtle bg-white p-block shadow-card">
					<SectionHeading>通常プラン</SectionHeading>
					<p class="mt-element text-text-muted">予約不要・来店順。時間帯ごとに異なる4種類の瞑想プログラムを体験できます。</p>
					<p class="mt-content">
						<strong>料金</strong> 3,000円/人 ｜
						<strong>定員</strong> 5名 ｜
						<strong>予約</strong> 不要
					</p>
				</div>

				<div class="rounded-subtle bg-white p-block shadow-card">
					<SectionHeading>営業カレンダー</SectionHeading>
					<WeekCalendar client:load events={regularPlanEvents} />
				</div>

				<div class="rounded-subtle bg-white p-block shadow-card">
					<SectionHeading>ご来店時の注意事項</SectionHeading>
					<ul class="mt-content mb-block ml-content list-disc">
						<li class="leading-list">各回開始の<strong>5分前まで</strong>にご来店ください</li>
						<li class="leading-list">開始時刻を過ぎると入店できません</li>
						<li class="leading-list">5名に達した場合、その回の受付は終了となります</li>
						<li class="leading-list">静寂瞑想でイヤホンをご使用の場合、音漏れにご注意ください（骨伝導イヤホンは使用不可）</li>
					</ul>
					<ul class="mt-content mb-block ml-content list-disc">
						<li class="leading-list">店舗の性質上、お電話での対応が難しいため、ご質問は<a href="mailto:meisou.kanoke.in@gmail.com" class="text-accent underline">メール</a>もしくは<a href={GOOGLE_FORM_CONTACT_URL} target="_blank" rel="noopener noreferrer" class="text-accent underline">お問い合わせフォーム</a>にてお願いします</li>
						<li class="leading-list">当店は宗教施設ではございません</li>
					</ul>
					<p class="mt-content text-small text-text-muted">営業時間: 奇数時間スタート（11〜17時）・定休日: 月曜・火曜</p>
					<p class="mt-content text-small text-text-muted">※ 営業時間の急な変更もあるため、来店前にカレンダーをご確認ください</p>
				</div>

				<div class="flex justify-center">
					<Button href="/#plans" variant="outline">戻る</Button>
				</div>
			</Stack>
		</Container>
	</section>
</BaseLayout>
