---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import Button from "../../components/Button.astro";
import Container from "../../components/Container.astro";
import Stack from "../../components/Stack.astro";
import WeekCalendar from "../../components/WeekCalendar.tsx";
import { privatePlanEvents } from "../../lib/calendar-data";
import { GOOGLE_FORM_CONTACT_URL, GOOGLE_FORM_PRIVATE_URL } from "../../consts";

const programs = [
	{ name: "リラックス瞑想", desc: "ヒーリング音楽" },
	{ name: "お経瞑想", desc: "読経の声に包まれる、少し特別な時間" },
	{ name: "シンギングボウル瞑想", desc: "鉢鐘の響きを感じる瞑想時間" },
	{ name: "静寂瞑想", desc: "BGMなしの静かな棺おけ体験" },
	{ name: "持参音楽プラン", desc: "好きな音楽を店内スピーカーで再生" },
];

const recommendItems = [
	"通常プランの時間が合わない方",
	"ひとりで体験したい、または気の合う人とだけで体験したい方",
	"人数が集まり少しお得に利用したい方（例: 4名の場合1人2,500円）",
];
---

<BaseLayout title="貸切プラン" description="好きなプログラムを選べる1組限定の貸切体験。">
	<section class="py-section">
		<Container width="wide">
			<Stack gap="content">
				<div class="rounded-subtle bg-white p-block shadow-card">
					<SectionHeading>貸切プラン</SectionHeading>
					<p class="mt-element text-text-muted">好きなプログラムを選べる1組限定の貸切体験。通常プランの4種類すべてのプログラムに加え、お持ちの音楽を店内スピーカーで再生するプランもお選びいただけます。</p>
					<p class="mt-content">
						<strong>料金</strong> 10,000円/枠 ｜
						<strong>定員</strong> 1〜5名 ｜
						<strong>所要時間</strong> 約60分
					</p>

					<h3 class="subsection-heading mt-block">プログラム一覧</h3>
					<div class="overflow-x-auto">
						<table class="w-full border-collapse">
							<thead>
								<tr>
									<th class="border-b-2 border-text px-content py-element text-left font-bold">プログラム</th>
									<th class="border-b-2 border-text px-content py-element text-left font-bold">内容</th>
								</tr>
							</thead>
							<tbody>
								{programs.map((p, i) => (
									<tr>
										<td class={`px-content py-element ${i < programs.length - 1 ? "border-b border-border" : ""}`}>{i === programs.length - 1 ? <strong>{p.name}</strong> : p.name}</td>
										<td class={`px-content py-element ${i < programs.length - 1 ? "border-b border-border" : ""}`}>{i === programs.length - 1 ? <strong>{p.desc}</strong> : p.desc}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>

					<h3 class="subsection-heading mt-block">こんな方におすすめ</h3>
					<ul class="ml-content flex list-disc flex-col gap-inset">
						{recommendItems.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</div>

				<div class="rounded-subtle bg-white p-block shadow-card">
					<SectionHeading>候補時間帯カレンダー</SectionHeading>
					<WeekCalendar client:load events={privatePlanEvents} mobileMode="symbol" />
				</div>

				<div class="rounded-subtle bg-white p-block shadow-card">
					<SectionHeading>ご予約・お問い合わせ</SectionHeading>

					<h3 class="subsection-heading mt-block">注意事項</h3>
					<ul class="my-content ml-content list-disc">
						<li class="leading-list">キャンセルは<strong>前日17:00まで</strong>にご連絡ください</li>
						<li class="leading-list">持参音楽プランの場合、音楽はCD・USBメモリ・スマートフォンに入れてお持ちください</li>
						<li class="leading-list">スマートフォン接続はイヤホンジャックまたはUSB type-C接続のみ対応（Bluetooth不可）</li>
						<li class="leading-list">稀に音響機器と接続できない場合があります</li>
						<li class="leading-list">店舗の性質上、お電話での対応が難しいため、ご質問は<a href="mailto:meisou.kanoke.in@gmail.com" class="text-accent underline">メール</a>もしくは<a href={GOOGLE_FORM_CONTACT_URL} target="_blank" rel="noopener noreferrer" class="text-accent underline">お問い合わせフォーム</a>にてお願いします</li>
						<li class="leading-list">当店は宗教施設ではございません</li>
					</ul>
					<p class="mt-content text-small text-text-muted">営業時間: 偶数時間スタート（12〜18時）・定休日: 月曜・火曜</p>

					<div class="mt-block flex justify-center">
						<Button href={GOOGLE_FORM_PRIVATE_URL} target="_blank">ご予約・お問い合わせはこちら</Button>
					</div>
				</div>

				<div class="flex justify-center">
					<Button href="/#plans" variant="outline">戻る</Button>
				</div>
			</Stack>
		</Container>
	</section>
</BaseLayout>

<style>
	.subsection-heading {
		display: inline-block;
		margin-bottom: var(--spacing-element);
		padding-bottom: var(--spacing-element);
		border-bottom: 2px solid var(--color-text);
		font-weight: var(--font-weight-bold);
	}
</style>
