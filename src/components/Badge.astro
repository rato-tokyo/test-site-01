---
interface Props {
	variant?: "cta" | "dark";
}

const { variant = "dark" } = Astro.props;
---

<span class:list={["badge", `badge-${variant}`]}>
	<slot />
</span>

<style>
	.badge {
		display: inline-flex;
		align-items: center;
		padding: var(--spacing-1) var(--spacing-2);
		font-size: 0.75rem;
		font-weight: 700;
		color: white;
	}

	.badge-cta {
		background: var(--color-cta);
	}

	.badge-dark {
		background: #404040;
	}
</style>
