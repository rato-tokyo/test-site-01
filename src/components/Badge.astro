---
/**
 * Badge — 小さなラベル。予約不要/定員 等の属性表示に使う。
 *
 * - `cta`: 赤背景(重要な訴求)
 * - `dark`: 濃グレー背景(通常ラベル)
 */
interface Props {
	variant?: 'cta' | 'dark';
}

const { variant = 'dark' } = Astro.props;

const base = 'inline-flex items-center px-element py-inset text-caption font-bold text-white';

const variantClass = {
	cta: 'bg-danger',
	dark: 'bg-badge-dark',
}[variant];
---

<span class:list={[base, variantClass]}>
	<slot />
</span>
