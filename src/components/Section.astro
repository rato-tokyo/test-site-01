---
/**
 * Section — ページ内セクションの垂直パディングを担うプリミティブ。
 * `<section>` タグを出力し、上下に意味ベースの余白を付ける。
 *
 * - `py`: 'comfortable' | 'loose' | 'section' — 上下パディングの大きさ
 * - `id`: アンカー用 ID
 */
interface Props {
	py?: 'comfortable' | 'loose' | 'section';
	id?: string;
	class?: string;
}

const { py = 'loose', id, class: className = '' } = Astro.props;

const pyClass = {
	comfortable: 'py-comfortable',
	loose: 'py-loose',
	section: 'py-section',
}[py];
---

<section id={id} class:list={[pyClass, className]}>
	<slot />
</section>
