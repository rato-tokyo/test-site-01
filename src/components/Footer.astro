---
import { SITE_TITLE } from '../consts';
---

<footer class="bg-footer-bg text-footer-text">
	<div class="mx-auto max-w-wide px-content pt-region pb-block">
		<div
			class="mb-block flex items-start justify-between gap-block max-lg:flex-col max-lg:gap-content"
		>
			<div class="max-w-content">
				<a
					href="/"
					class="font-heading text-h4 font-semibold text-white no-underline"
					>{SITE_TITLE}</a
				>
				<p class="mt-element text-small text-footer-muted">日本で唯一の瞑想空間</p>
				<p class="mt-element text-small text-footer-subtle">〒169-0075 東京都新宿区高田馬場 1-29-7 スカイパレスビル 801</p>
				<p class="mt-inset text-small text-footer-subtle">定休日: 月曜・火曜 ｜ <a href="mailto:meisou.kanoke.in@gmail.com" class="text-footer-subtle no-underline transition-colors duration-fast hover:text-white">meisou.kanoke.in@gmail.com</a></p>
			</div>
			<nav
				class="flex shrink-0 flex-wrap justify-end gap-content text-small max-lg:max-w-full max-lg:justify-start max-lg:gap-element"
			>
				<a href="/" class="text-footer-subtle no-underline transition-colors duration-fast hover:text-white">ホーム</a>
				<a href="/#plans" class="text-footer-subtle no-underline transition-colors duration-fast hover:text-white">プラン</a>
				<a href="/#access" class="text-footer-subtle no-underline transition-colors duration-fast hover:text-white">アクセス</a>
				<a href="/#faq" class="text-footer-subtle no-underline transition-colors duration-fast hover:text-white">Q&amp;A</a>
				<a href="/blog" class="text-footer-subtle no-underline transition-colors duration-fast hover:text-white">ブログ</a>
			</nav>
		</div>
		<div
			class="flex items-center justify-center border-t border-footer-divider pt-block max-sm:flex-col max-sm:gap-content max-sm:text-center"
		>
			<p class="text-small text-footer-faint">© 2026 {SITE_TITLE}</p>
		</div>
	</div>
</footer>
