---
import { SITE_TITLE } from '../consts';
---

<footer class="site-footer">
	<div class="footer-inner">
		<div class="footer-simple">
			<div class="footer-brand">
				<a href="/" class="footer-logo">{SITE_TITLE}</a>
				<p class="footer-tagline">ダミーのタグラインが入ります</p>
				<p class="footer-address">〒000-0000 ダミー住所 1-2-3 ダミービル 4階</p>
				<p class="footer-meta">定休日: 月曜・火曜 ｜ <a href="mailto:example@example.com">example@example.com</a></p>
			</div>
			<nav class="footer-nav-simple">
				<a href="/">ホーム</a>
				<a href="/blog">ブログ</a>
				<a href="/about">About</a>
				<a href="/#plans">プラン</a>
				<a href="/#access">アクセス</a>
				<a href="/#faq">Q&amp;A</a>
			</nav>
		</div>
		<div class="footer-bottom">
			<p class="footer-copyright">© {new Date().getFullYear()} {SITE_TITLE}</p>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		background: #000000;
		color: #e0e0e0;
		border-top: none;
	}

	.footer-inner {
		max-width: 64rem;
		margin: 0 auto;
		padding: var(--spacing-16) 1rem var(--spacing-8);
	}

	.footer-simple {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: var(--spacing-8);
		margin-bottom: var(--spacing-8);
	}

	.footer-brand {
		max-width: 400px;
	}

	.footer-logo {
		font-family: var(--font-heading);
		font-size: var(--font-size-xl);
		font-weight: 600;
		color: #ffffff;
		text-decoration: none;
		letter-spacing: var(--tracking-snug);
	}

	.footer-tagline {
		margin-top: var(--spacing-2);
		font-size: var(--font-size-sm);
		color: #999999;
	}

	.footer-address {
		margin-top: var(--spacing-2);
		font-size: var(--font-size-sm);
		color: #bbbbbb;
	}

	.footer-meta {
		margin-top: var(--spacing-1);
		font-size: var(--font-size-sm);
		color: #bbbbbb;
	}

	.footer-meta a {
		color: #bbbbbb;
	}

	.footer-nav-simple {
		display: flex;
		gap: var(--spacing-5);
		font-size: var(--font-size-sm);
		flex-shrink: 0;
		flex-wrap: wrap;
		max-width: 50%;
		justify-content: flex-end;
	}

	.footer-nav-simple a {
		color: #bbbbbb;
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.footer-nav-simple a:hover {
		color: #ffffff;
	}

	.footer-bottom {
		display: flex;
		justify-content: center;
		align-items: center;
		padding-top: var(--spacing-6);
		border-top: 1px solid #333333;
	}

	.footer-copyright {
		font-size: var(--font-size-sm);
		color: #777777;
	}

	@media (max-width: 900px) {
		.footer-simple {
			flex-direction: column;
			gap: var(--spacing-4);
		}

		.footer-nav-simple {
			flex-wrap: wrap;
			gap: var(--spacing-3);
			max-width: 100%;
			justify-content: flex-start;
		}
	}

	@media (max-width: 640px) {
		.footer-bottom {
			flex-direction: column;
			gap: var(--spacing-4);
			text-align: center;
		}
	}
</style>
