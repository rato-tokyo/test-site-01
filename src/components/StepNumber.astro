---
/**
 * StepNumber — ステップの順番を示す丸いバッジ。
 * w-icon / h-icon (32px) の正方形を pill 形状で。
 */
interface Props {
	num: number;
}

const { num } = Astro.props;
---

<span
	class="flex h-icon w-icon shrink-0 items-center justify-center rounded-pill bg-accent text-small font-bold text-text-on-brand"
>
	{num}
</span>
