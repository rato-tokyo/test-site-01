---
/**
 * Stack — 子要素を縦に等間隔に並べるプリミティブ(Every Layout 由来)。
 *
 * - `gap`: 'element' | 'content' | 'block' | 'region' | 'section'
 * - `as`: ラップするタグ(デフォルト div)
 */
interface Props {
	gap?: 'element' | 'content' | 'block' | 'region' | 'section';
	as?: keyof HTMLElementTagNameMap;
	class?: string;
}

const { gap = 'content', as: Tag = 'div', class: className = '' } = Astro.props;

const gapClass = {
	element: 'space-y-element',
	content: 'space-y-content',
	block: 'space-y-block',
	region: 'space-y-region',
	section: 'space-y-section',
}[gap];
---

<Tag class:list={[gapClass, className]}>
	<slot />
</Tag>
