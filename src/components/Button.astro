---
/**
 * Button — プライマリ/アウトラインの 2 バリアント。
 *
 * href を渡すと <a>、省略すると <button> として出力する。
 * max-w-button (300px) で親要素の中央に配置される想定。
 */
interface Props {
	href?: string;
	variant?: 'primary' | 'outline';
	type?: 'button' | 'submit' | 'reset';
	class?: string;
}

const { href, variant = 'primary', type = 'button', class: className = '' } = Astro.props;

const base =
	'flex w-full max-w-button items-center justify-center rounded-subtle border-2 p-snug text-small font-bold no-underline transition-colors duration-fast cursor-pointer';

const variantClass = {
	primary: 'border-accent bg-accent text-text-on-brand hover:bg-accent-hover',
	outline: 'border-accent bg-white text-accent hover:bg-accent hover:text-text-on-brand',
}[variant];
---

{href ? (
	<a href={href} class:list={[base, variantClass, className]}>
		<slot />
	</a>
) : (
	<button type={type} class:list={[base, variantClass, className]}>
		<slot />
	</button>
)}
