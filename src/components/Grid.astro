---
/**
 * Grid — CSS Grid のラッパープリミティブ。
 *
 * - `cols`: 'auto' (auto-fill minmax) / 'main-sidebar' (メイン + サイドバー、lg 以上) / 'halves' (2 等分、md 以上) / 'thirds' (3 等分、md 以上)
 * - `gap`: 'element' | 'content' | 'block'
 */
interface Props {
	cols?: 'auto' | 'main-sidebar' | 'halves' | 'thirds';
	gap?: 'element' | 'content' | 'block';
	class?: string;
}

const { cols = 'auto', gap = 'content', class: className = '' } = Astro.props;

const gapClass = {
	element: 'gap-element',
	content: 'gap-content',
	block: 'gap-block',
}[gap];
---

<div class:list={['grid', gapClass, className]} data-cols={cols}>
	<slot />
</div>

<style>
	[data-cols="auto"] {
		grid-template-columns: var(--grid-template-columns-recommend);
	}
	[data-cols="main-sidebar"] {
		grid-template-columns: 1fr;
	}
	@media (min-width: 1024px) {
		[data-cols="main-sidebar"] {
			grid-template-columns: minmax(0, 1fr) var(--container-sidebar);
		}
	}
	[data-cols="halves"] {
		grid-template-columns: 1fr;
	}
	@media (min-width: 768px) {
		[data-cols="halves"] {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	[data-cols="thirds"] {
		grid-template-columns: 1fr;
	}
	@media (min-width: 768px) {
		[data-cols="thirds"] {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
