---
/**
 * Container — ページ幅を制限する外枠プリミティブ。
 *
 * - `width`: 'content' (読み物系: 48rem 相当) / 'wide' (標準: 64rem 相当) / 'full' (制限なし)
 * - 左右に content の padding を入れる(モバイルでのはみ出し防止)
 */
interface Props {
	width?: 'content' | 'wide' | 'full';
	as?: keyof HTMLElementTagNameMap;
	class?: string;
}

const { width = 'wide', as: Tag = 'div', class: className = '' } = Astro.props;

const widthClass = {
	content: 'max-w-content',
	wide: 'max-w-wide',
	full: '',
}[width];
---

<Tag class:list={['mx-auto w-full px-content', widthClass, className]}>
	<slot />
</Tag>
