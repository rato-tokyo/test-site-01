---
/**
 * SectionCard — 白背景の区画カード。
 * 本番 kanoke-in の shadcn Card を意味ベーストークンに寄せた実装。
 */
interface Props {
	id?: string;
	class?: string;
}

const { id, class: className = '' } = Astro.props;
---

<section
	id={id}
	class:list={['rounded-subtle bg-white p-comfortable shadow-card', className]}
>
	<slot />
</section>
